# Admin password — LOCAL DEV ONLY
#
# This is NOT how you set the password on your live GitHub Pages site.
# On Pages, there is no server reading .env. Set it here instead:
#
#   GitHub repo → Settings → Secrets and variables → Actions
#   → New repository secret → Name: ADMIN_PASSWORD
#
# GitHub Actions hashes that secret at deploy time and bakes it into the site.
# You sign in to /admin.html with the same plain password you put in the secret.
#
# Only use this file if you're testing admin locally:
#   cp .env.example .env
#   node scripts/setup-admin.mjs
#   python3 -m http.server 8080
#
# .env is gitignored — never commit it.

ADMIN_PASSWORD=change-me-to-something-strong
